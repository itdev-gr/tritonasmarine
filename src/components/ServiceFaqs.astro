---
import type { Locale } from "../i18n/utils";
import type { Faq } from "../data/services";
import { t, localizedPath } from "../i18n/utils";
import { Plus, Minus } from "lucide-astro";

export interface Props {
  locale: Locale;
  faqs: Faq[];
}

const { locale, faqs } = Astro.props;
---

<section class="bg-foam">
  <div class="mx-auto grid max-w-[1200px] gap-12 px-6 py-20 md:grid-cols-[2fr_3fr] md:gap-16">
    <div data-reveal>
      <h2 class="font-display text-navy text-4xl font-semibold sm:text-5xl">
        {t(locale, "faq.heading")}
      </h2>
      <div class="bg-rust mt-6 h-1 w-16 rounded-full"></div>
      <p class="text-navy/75 mt-6 max-w-sm">{t(locale, "faq.intro")}</p>
      <a
        href={localizedPath(locale, "/contact")}
        class="bg-rust text-foam hover:bg-navy mt-8 inline-flex items-center rounded-lg px-6 py-3 text-sm font-semibold uppercase tracking-wide transition"
      >
        {t(locale, "faq.cta")}
      </a>
    </div>

    <div class="space-y-3" data-reveal>
      {
        faqs.map((faq, i) => (
          <details
            class="group border-navy/10 bg-foam rounded-lg border px-6 py-5 transition open:shadow-sm"
            open={i === 0}
          >
            <summary class="flex cursor-pointer list-none items-start justify-between gap-6">
              <h3 class="text-navy text-base font-semibold sm:text-lg">
                {faq.question[locale]}
              </h3>
              <span class="bg-rust text-foam flex h-7 w-7 flex-none items-center justify-center rounded-full transition">
                <Plus class="h-4 w-4 group-open:hidden" />
                <Minus class="hidden h-4 w-4 group-open:block" />
              </span>
            </summary>
            <p class="text-navy/75 mt-3 pr-12 text-sm leading-relaxed sm:text-base">
              {faq.answer[locale]}
            </p>
          </details>
        ))
      }
    </div>
  </div>
</section>
