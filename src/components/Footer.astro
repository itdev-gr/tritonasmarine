---
import type { Locale } from "../i18n/utils";
import { t, localizedPath } from "../i18n/utils";

export interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const year = new Date().getFullYear();

const nav = [
  { key: "nav.home", href: localizedPath(locale, "/") },
  { key: "nav.about", href: localizedPath(locale, "/about") },
  { key: "nav.community", href: localizedPath(locale, "/community") },
  { key: "nav.services", href: localizedPath(locale, "/services") },
  { key: "nav.contact", href: localizedPath(locale, "/contact") },
] as const;
---

<footer class="bg-navy text-foam">
  <div class="mx-auto grid max-w-[1200px] gap-10 px-6 py-16 md:grid-cols-4">
    <div>
      <div class="flex items-center gap-2">
        <img
          src="/logo-mark.svg"
          alt=""
          class="h-9 w-auto brightness-0 invert"
          width="48"
          height="88"
          aria-hidden="true"
        />
        <span class="font-display text-xl font-semibold">Triton Marine</span>
      </div>
      <p class="text-foam/70 mt-3 text-sm">{t(locale, "footer.tagline")}</p>
    </div>

    <nav aria-label="Footer navigation">
      <h2 class="text-foam/60 text-sm font-semibold tracking-wide uppercase">
        {t(locale, "nav.services")}
      </h2>
      <ul class="mt-3 space-y-2 text-sm">
        {
          nav.map((item) => (
            <li>
              <a href={item.href} class="text-foam/85 hover:text-teal transition">
                {t(locale, item.key)}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div>
      <h2 class="text-foam/60 text-sm font-semibold tracking-wide uppercase">
        {t(locale, "footer.address_label")}
      </h2>
      <p class="text-foam/85 mt-3 text-sm">Placeholder address<br />Placeholder city, Greece</p>
      <p class="mt-3 text-sm">
        <span class="text-foam/60">{t(locale, "footer.phone_label")}:</span>
        <a href="tel:+300000000000" class="text-foam/85 hover:text-teal ml-1">+30 000 000 0000</a>
      </p>
      <p class="text-sm">
        <span class="text-foam/60">{t(locale, "footer.email_label")}:</span>
        <a href="mailto:info@tritonasmarine.gr" class="text-foam/85 hover:text-teal ml-1"
          >info@tritonasmarine.gr</a
        >
      </p>
    </div>

    <div>
      <h2 class="text-foam/60 text-sm font-semibold tracking-wide uppercase">Hours</h2>
      <p class="text-foam/85 mt-3 text-sm">
        Mon – Fri: 08:00 – 18:00<br />Sat: 09:00 – 14:00<br />Sun: Closed
      </p>
    </div>
  </div>

  <div class="border-foam/10 border-t">
    <div
      class="text-foam/60 mx-auto flex max-w-[1200px] flex-col items-center justify-between gap-2 px-6 py-6 text-xs md:flex-row"
    >
      <p>© {year} Triton Marine. {t(locale, "footer.rights")}</p>
      <p>
        Powered by
        <a
          href="https://www.itdev.gr"
          target="_blank"
          rel="noopener"
          class="hover:text-teal font-semibold underline-offset-2 hover:underline"
        >
          ITDEV
        </a>
      </p>
    </div>
  </div>
</footer>
