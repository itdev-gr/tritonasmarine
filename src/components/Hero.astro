---
import type { Locale } from "../i18n/utils";
import { t, localizedPath } from "../i18n/utils";

export interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<section class="bg-navy text-foam relative isolate overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <video
      src="/videos/hero-home.mp4"
      poster="/images/hero-home.jpg"
      class="h-full w-full object-cover opacity-60"
      data-hero-video
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      aria-hidden="true"></video>
    <div class="from-navy/60 via-navy/40 to-navy absolute inset-0 bg-gradient-to-b"></div>
  </div>

  <div class="mx-auto flex min-h-[80vh] max-w-[1200px] flex-col justify-center px-6 py-24">
    <p class="text-teal text-xs font-semibold tracking-[0.2em] uppercase" data-reveal>
      {t(locale, "hero.eyebrow")}
    </p>
    <h1
      class="font-display mt-6 max-w-3xl text-5xl leading-tight font-semibold sm:text-6xl md:text-7xl"
      data-hero-title
    >
      {t(locale, "hero.title")}
    </h1>
    <p class="text-foam/85 mt-6 max-w-xl text-lg" data-reveal>
      {t(locale, "hero.subtitle")}
    </p>
    <div class="mt-10 flex flex-wrap gap-3" data-reveal>
      <a
        href={localizedPath(locale, "/services")}
        class="bg-teal text-foam hover:bg-foam hover:text-navy rounded-lg px-6 py-3 text-sm font-semibold transition"
      >
        {t(locale, "hero.cta_primary")}
      </a>
      <a
        href={localizedPath(locale, "/contact")}
        class="border-foam/40 text-foam hover:bg-foam hover:text-navy rounded-lg border px-6 py-3 text-sm font-semibold transition"
      >
        {t(locale, "hero.cta_secondary")}
      </a>
    </div>
  </div>
</section>
