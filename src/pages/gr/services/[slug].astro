---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import PageHero from "../../../components/PageHero.astro";
import ProcessSteps from "../../../components/ProcessSteps.astro";
import ServiceFaqs from "../../../components/ServiceFaqs.astro";
import RelatedServices from "../../../components/RelatedServices.astro";
import CtaSection from "../../../components/CtaSection.astro";
import { services } from "../../../data/services";
import { t, localizedPath } from "../../../i18n/utils";
import { CircleDollarSign, UsersRound, BadgeCheck, Camera } from "lucide-astro";

export function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug } }));
}

const locale = "gr" as const;
const { slug } = Astro.params;
const service = services.find((s) => s.slug === slug)!;
---

<BaseLayout
  locale={locale}
  title={`${service.name.gr} — Triton Marine`}
  description={service.shortDescription.gr}
>
  <Header slot="header" locale={locale} />

  <PageHero
    locale={locale}
    title={service.name.gr}
    backgroundImage={service.heroImage}
    crumbs={[
      { labelKey: "breadcrumb.home", href: "/" },
      { labelKey: "breadcrumb.services", href: "/services" },
      { labelKey: "breadcrumb.services" },
    ]}
  />

  <!-- Section 1 -->
  <section class="bg-foam">
    <div class="mx-auto max-w-[760px] px-6 py-24 text-center">
      <p class="text-teal text-xs font-semibold tracking-[0.22em] uppercase" data-reveal>
        {service.eyebrow.gr}
      </p>
      <h2
        class="font-display text-navy mt-6 text-4xl leading-tight font-semibold sm:text-5xl"
        data-reveal
      >
        {service.shortDescription.gr}
      </h2>
      <div class="text-navy/80 mt-8 space-y-4 text-left text-lg leading-relaxed" data-reveal>
        {service.intro.map((p) => <p>{p.gr}</p>)}
      </div>
    </div>
  </section>

  <!-- Section 2 -->
  <section class="bg-navy text-foam">
    <div class="mx-auto grid max-w-[1200px] gap-12 px-6 py-24 md:grid-cols-12 md:items-center">
      <div class="grid gap-4 md:col-span-6" data-reveal>
        {
          service.galleryImages.map((src) => (
            <div class="overflow-hidden rounded-lg">
              <img src={src} alt="" class="aspect-[4/3] h-full w-full object-cover" loading="lazy" />
            </div>
          ))
        }
      </div>
      <div class="md:col-span-6" data-reveal>
        <p class="text-teal text-xs font-semibold tracking-[0.22em] uppercase">
          {t(locale, "service.benefits_eyebrow")}
        </p>
        <h2 class="font-display mt-4 text-3xl font-semibold sm:text-4xl">
          {t(locale, "service.benefits_title")}
        </h2>
        <div class="mt-10 grid gap-5 sm:grid-cols-2">
          <div class="border-foam/10 rounded-lg border p-5">
            <CircleDollarSign class="text-teal h-6 w-6" />
            <h3 class="font-display mt-3 text-lg font-semibold">
              {t(locale, "service.benefit_1_title")}
            </h3>
            <p class="text-foam/70 mt-2 text-sm leading-relaxed">
              {t(locale, "service.benefit_1_body")}
            </p>
          </div>
          <div class="border-foam/10 rounded-lg border p-5">
            <UsersRound class="text-teal h-6 w-6" />
            <h3 class="font-display mt-3 text-lg font-semibold">
              {t(locale, "service.benefit_2_title")}
            </h3>
            <p class="text-foam/70 mt-2 text-sm leading-relaxed">
              {t(locale, "service.benefit_2_body")}
            </p>
          </div>
          <div class="border-foam/10 rounded-lg border p-5">
            <BadgeCheck class="text-teal h-6 w-6" />
            <h3 class="font-display mt-3 text-lg font-semibold">
              {t(locale, "service.benefit_3_title")}
            </h3>
            <p class="text-foam/70 mt-2 text-sm leading-relaxed">
              {t(locale, "service.benefit_3_body")}
            </p>
          </div>
          <div class="border-foam/10 rounded-lg border p-5">
            <Camera class="text-teal h-6 w-6" />
            <h3 class="font-display mt-3 text-lg font-semibold">
              {t(locale, "service.benefit_4_title")}
            </h3>
            <p class="text-foam/70 mt-2 text-sm leading-relaxed">
              {t(locale, "service.benefit_4_body")}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3 -->
  <ProcessSteps
    locale={locale}
    heading={t(locale, "process.how_it_works")}
    steps={service.processSteps}
  />

  <!-- Section 4 -->
  <section class="bg-sand">
    <div class="mx-auto max-w-[900px] px-6 py-24">
      <div class="text-navy/85 space-y-5 text-lg leading-relaxed" data-reveal>
        {service.conclusion.map((p) => <p>{p.gr}</p>)}
      </div>
    </div>
    <ServiceFaqs locale={locale} faqs={service.faqs} />

    <div class="bg-rust text-foam">
      <div
        class="mx-auto flex max-w-[1200px] flex-col items-start gap-6 px-6 py-12 md:flex-row md:items-center md:justify-between"
      >
        <div data-reveal>
          <p class="text-foam/70 text-xs font-semibold tracking-[0.22em] uppercase">
            {t(locale, "service.cta_eyebrow")}
          </p>
          <p class="font-display mt-2 max-w-2xl text-2xl font-semibold sm:text-3xl">
            {t(locale, "service.cta_title")}
          </p>
        </div>
        <a
          href={localizedPath(locale, "/contact")}
          class="bg-foam text-navy hover:bg-navy hover:text-foam rounded-lg px-6 py-3 text-sm font-semibold transition"
          data-reveal
        >
          {t(locale, "cta.button")}
        </a>
      </div>
    </div>
  </section>

  <RelatedServices locale={locale} currentSlug={service.slug} />

  <CtaSection locale={locale} />

  <Footer slot="footer" locale={locale} />
</BaseLayout>
