---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { t, localizedPath } from "../../i18n/utils";

const locale = "gr" as const;
---

<BaseLayout
  locale={locale}
  title="Η σελίδα δεν βρέθηκε — Triton Marine"
  description="Η σελίδα που ψάχνετε δεν υπάρχει."
>
  <Header slot="header" locale={locale} />

  <section class="bg-navy text-foam relative overflow-hidden">
    <div class="from-navy via-deep to-navy pointer-events-none absolute inset-0 bg-gradient-to-br opacity-90"></div>
    <div
      class="relative mx-auto flex min-h-[70vh] max-w-[1200px] flex-col items-start justify-center px-6 py-24"
    >
      <p class="text-teal text-xs font-semibold tracking-[0.22em] uppercase" data-reveal>
        {t(locale, "notfound.eyebrow")}
      </p>
      <p class="font-display text-teal mt-2 text-[10rem] leading-none font-semibold" data-reveal>
        404
      </p>
      <h1 class="font-display mt-2 text-4xl font-semibold sm:text-5xl" data-reveal>
        {t(locale, "notfound.title")}
      </h1>
      <p class="text-foam/80 mt-3 max-w-xl" data-reveal>
        {t(locale, "notfound.subtitle")}
      </p>
      <div class="mt-10 flex flex-wrap gap-3" data-reveal>
        <a
          href={localizedPath(locale, "/")}
          class="bg-teal text-foam hover:bg-foam hover:text-navy rounded-lg px-6 py-3 text-sm font-semibold transition"
        >
          {t(locale, "notfound.cta")}
        </a>
        <a
          href={localizedPath(locale, "/services")}
          class="border-foam/40 text-foam hover:bg-foam hover:text-navy rounded-lg border px-6 py-3 text-sm font-semibold transition"
        >
          {t(locale, "notfound.cta_alt")}
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" locale={locale} />
</BaseLayout>
